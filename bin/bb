#!/usr/bin/env python3

import os, sys, json, boto3, functools, signal
from botocore.config import Config
from pathlib import Path
signal.signal(signal.SIGPIPE, signal.SIG_DFL)


CREDS_PATH = Path(os.path.expanduser('~/.config/b2-secrets.json'))

def get_b2_client():
    creds = json.loads(CREDS_PATH.read_text())
    return boto3.client(
        's3',
        endpoint_url=creds['url'],
        aws_access_key_id=creds['key_id'],
        aws_secret_access_key=creds['application_key'],
        config=Config(signature_version='s3v4')
    )

def parse_bkt(s):
    if s in ['','.']:
        creds = json.loads(CREDS_PATH.read_text())
        return creds['default_bucket']
    return s

def main():
    if len(sys.argv) < 2:
        print("Usage: b2 [list-buckets | list-files <bkt> | upload <bkt> <local> <remote> | cat <bkt> <path>]")
        print('Buckets:')
        for b in get_b2_client().list_buckets().get('Buckets', []):
            print(' -', b['Name'])
        sys.exit(1)

    cmd = sys.argv[1]
    s3 = get_b2_client()

    if cmd == "list-buckets":
        res = s3.list_buckets()
        for b in res.get('Buckets', []):
            print(b['Name'])

    elif cmd in ["list-files",'ls']:
        if len(sys.argv) < 3:
            print("Usage: b2 list-files <bkt>")
            sys.exit(1)
        bkt = parse_bkt(sys.argv[2])
        res = s3.list_objects_v2(Bucket=bkt)
        for obj in res.get('Contents', []):
            print(f"{obj['Key']} ({obj['Size']} bytes)")

    elif cmd == "upload":
        if len(sys.argv) < 5:
            print("Usage: b2 upload <bkt> <key> <path>")
            sys.exit(1)
        bkt, key, path = parse_bkt(sys.argv[2]), sys.argv[3], sys.argv[4]
        print(f"Uploading {path} -> {bkt}/{key}...")
        s3.upload_file(path, bkt, key)
        print("Upload successful.")

    elif cmd == "download":
        if len(sys.argv) < 5:
            print("Usage: b2 download <bkt> <key> <path>")
            sys.exit(1)
        bkt, key, path = parse_bkt(sys.argv[2]), sys.argv[3], sys.argv[4]
        print(f"Downloading {bkt}/{key} -> {path}...")
        s3.download_file(bkt, key, path)
        print("Download successful.")

    elif cmd == "cat":
        if len(sys.argv) < 4:
            print("Usage: b2 cat <bucket> <key>")
            sys.exit(1)
        bkt, key = parse_bkt(sys.argv[2]), sys.argv[3]
        res = s3.get_object(Bucket=bkt, Key=key)
        sys.stdout.buffer.write(res['Body'].read())

    else:
        print(f"Unknown command: {cmd}")

if __name__ == "__main__":
    main()
