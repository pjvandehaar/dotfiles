#!/usr/bin/env python3

import os, sys, json, boto3
from botocore.config import Config
from pathlib import Path

CREDS_PATH = Path(os.path.expanduser('~/.config/b2-secrets.json'))

def get_b2_client():
    creds = json.loads(CREDS_PATH.read_text())
    return boto3.client(
        's3',
        endpoint_url=creds['url'],
        aws_access_key_id=creds['key_id'],
        aws_secret_access_key=creds['application_key'],
        config=Config(signature_version='s3v4')
    )

def main():
    if len(sys.argv) < 2:
        print("Usage: b2 [list-buckets | list-files <bkt> | upload <bkt> <local> <remote> | cat <bkt> <path>]")
        sys.exit(1)

    cmd = sys.argv[1]
    s3 = get_b2_client()

    if cmd == "list-buckets":
        res = s3.list_buckets()
        for b in res.get('Buckets', []):
            print(b['Name'])

    elif cmd == "list-files":
        if len(sys.argv) < 3:
            print("Usage: b2 list-files <bucket>")
            sys.exit(1)
        bkt = sys.argv[2]
        res = s3.list_objects_v2(Bucket=bkt)
        for obj in res.get('Contents', []):
            print(f"{obj['Key']} ({obj['Size']} bytes)")

    elif cmd == "upload":
        if len(sys.argv) < 5:
            print("Usage: b2 upload <bucket> <local_path> <remote_path>")
            sys.exit(1)
        bkt, local, remote = sys.argv[2], sys.argv[3], sys.argv[4]
        print(f"Uploading {local} to {bkt}/{remote}...")
        # Managed upload: Automatically handles multi-part for large files
        s3.upload_file(local, bkt, remote)
        print("Upload successful.")

    elif cmd == "cat":
        if len(sys.argv) < 4:
            print("Usage: b2 cat <bucket> <remote_path>")
            sys.exit(1)
        bkt, remote = sys.argv[2], sys.argv[3]
        res = s3.get_object(Bucket=bkt, Key=remote)
        sys.stdout.buffer.write(res['Body'].read())

    else:
        print(f"Unknown command: {cmd}")

if __name__ == "__main__":
    main()
